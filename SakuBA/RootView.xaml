<Window x:Class="SakuBA.RootView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Saku Overclock"
        Icon="pack://application:,,,/SakuBA;component/Assets/StoreLogo.png"
        Width="650" Height="440"
        MinWidth="637" MinHeight="411"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing" AllowsTransparency="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/SakuBA;component/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="4" Background="#202020" BorderBrush="#3b3c3d" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            WindowChrome.IsHitTestVisibleInChrome="True">

                    <Button Command="{Binding MinimizeCommand}"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Content="&#xE921;" />

                    <Button Command="{Binding MaximizeCommand}"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Content="&#xE922;" />

                    <Button Command="{Binding CloseCommand}"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            Content="&#xE8BB;" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="24,0,21,17">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding LocalizedStatusTitle}"
                               Style="{StaticResource StateHeaderStyle}" />

                    <Image Grid.Column="1" Margin="0,0,11,-90"
                           Source="pack://application:,,,/SakuBA;component/Assets/StoreLogo.png"
                           Style="{StaticResource TopLogoStyle}" />
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,13,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="{Binding LocalizedPublisherLabel}" Style="{StaticResource MetaLabelStyle}" />
                            <TextBlock Margin="-5,2,0,0" Text="Saku Labs Inc." Style="{StaticResource MetaLabelStyle}" />
                        </StackPanel>
                        <StackPanel Margin="0,-2,0,0" Grid.Row="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding LocalizedVersionLabel}" Style="{StaticResource MetaLabelStyle}" />
                            <TextBlock Margin="-5,2,0,0" Text="{Binding DisplayVersion}"
                                       Style="{StaticResource MetaLabelStyle}" />
                        </StackPanel>
                        <StackPanel Margin="0,-1,0,0" Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="{Binding LocalizedSourceLabel}" Style="{StaticResource MetaLabelStyle}" />
                            <TextBlock Margin="-5,2,0,0" Text="{Binding DisplaySource}"
                                       Style="{StaticResource MetaLabelStyle}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding LocalizedFeaturesLabel}" Style="{StaticResource FeaturesHeaderStyle}" />
                    <ItemsControl ItemsSource="{Binding LocalizedFeaturesList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StringFormat='• {0}'}"
                                           Style="{StaticResource FeatureItemStyle}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,0,0,5">
                    <Border Height="3" CornerRadius="4"
                        Visibility="{Binding IsProgressState, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ProgressBar Value="{Binding ProgressViewModel.Progress}"
                                     Style="{StaticResource AppProgressBarStyle}" />
                    </Border>

                    <Grid
                        Visibility="{Binding IsNotProgressState, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding LaunchGitHubCommand}"
                                Style="{StaticResource InfoCircleButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◯" FontSize="19" Margin="0,0,2,0" />
                                <TextBlock Text="i" FontSize="10" FontWeight="Bold" Margin="-14,7,0,0" />
                            </StackPanel>
                        </Button>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding SecondaryActionCommand}"
                                    Content="{Binding LocalizedSecondaryActionText}"
                                    Style="{StaticResource FooterActionButtonStyle}" />
                            <Button Visibility="{Binding PrimaryButtonVisibility}"
                                    Command="{Binding PrimaryActionCommand}"
                                    Content="{Binding LocalizedPrimaryActionText}"
                                    Style="{StaticResource FooterActionButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>